<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BGMI ESP HACK - Premium Loader</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Roboto:wght@400;700;900&display=swap');

        body {
            font-family: 'Roboto', sans-serif;
            background-color: #fcf6e5;
            /* Matching the cream background from the image */
        }

        .telegram-btn {
            background: linear-gradient(to bottom, #b91c1c, #7f1d1d);
            transition: transform 0.2s;
        }

        .telegram-btn:active {
            transform: scale(0.98);
        }

        .dm-btn {
            background: linear-gradient(to right, #ff0000, #cc0000);
            border-radius: 9999px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.3);
        }

        .timer-unit {
            color: #b91c1c;
            font-weight: 700;
        }

        .hurry-up-text {
            font-size: 3rem;
            font-weight: 900;
        }

        .hurry-blue {
            color: #0000ff;
        }

        .up-red {
            color: #ff0000;
        }

        /* Animation for the "Hurry Up" comma */
        @keyframes blink {
            50% {
                opacity: 0;
            }
        }

        .blink {
            animation: blink 1s infinite;
        }
    </style>
</head>

<body class="max-w-md mx-auto shadow-2xl min-h-screen border-x border-gray-200">

    <!-- Top Header -->
    <header class="bg-white py-2 text-center border-b">
        <h1 class="text-2xl font-bold tracking-tight text-gray-800 uppercase">
            BGMI <span class="text-red-600">ESP</span> HACK
        </h1>
    </header>

    <!-- Subheader Notification Bar -->
    <div class="bg-[#f28b82] py-1 text-center">
        <p class="text-[10px] font-bold text-gray-900 uppercase tracking-widest">
            PREMIUM LOADER + MOD 4.3 JOIN NOW
        </p>
    </div>

    <!-- Main Content -->
    <main class="flex flex-col items-center px-4 py-6 space-y-6">

        <!-- Logo/Avatar Area -->
        <div
            class="relative w-48 h-48 rounded-full overflow-hidden border-4 border-gray-800 bg-black flex items-center justify-center">
            <!-- Using a representative gaming/hacker avatar -->
            <img src="logo.png" alt="Poison Hackes Logo" class="w-full h-full object-cover opacity-80"
                onerror="this.src='https://via.placeholder.com/200?text=POISON+HACKES'">
            <div class="absolute bottom-4 text-center w-full">
                <span class="text-[#39FF14] font-black text-xl italic tracking-tighter drop-shadow-md">POISON</span>
                <br>
                <span class="text-[#39FF14] font-bold text-xs tracking-widest">HACKES</span>
            </div>
        </div>

        <!-- Feature List Yellow Box -->
        <div class="bg-[#f7df72] p-4 rounded-sm text-center w-full shadow-sm">
            <ul class="space-y-1 font-bold text-gray-800 text-sm">
                <li>👇 BGMI Esp Aimbot Norecoil 🥳</li>
                <li>😈 Daily Free Esp Hack + Config 😈</li>
                <li>🎯 100% FULL SAFE MAIN ID 🎯</li>
                <li>👅 ANDROID + IOS BOTH SUPPORT 👅</li>
                <li>🧬 Conqueror + Leaderboard Guarentee 🏁</li>
            </ul>
        </div>

        <!-- Telegram Button 1 -->
        <a href="https://t.me/+jdK3-Zqi1A42NjM1"
            class="telegram-btn w-full flex items-center justify-between px-4 py-2 text-white rounded-sm shadow-md">
            <i class="fab fa-telegram-plane text-2xl"></i>
            <div class="text-center flex-1">
                <p class="font-bold text-lg leading-tight uppercase">JOIN TELEGRAM CHANNEL</p>
                <p class="text-xs">4.3 PAID HACK</p>
            </div>
            <i class="fab fa-telegram-plane text-2xl"></i>
        </a>

        <!-- Gameplay Screenshot -->
        <div class="w-full rounded-md overflow-hidden shadow-lg border-2 border-gray-300">
            <img src="game.png" alt="Gameplay" class="w-full object-cover">
        </div>

        <!-- Telegram Button 2 -->
        <a href="https://t.me/+jdK3-Zqi1A42NjM1"
            class="telegram-btn w-full flex items-center justify-between px-4 py-3 text-white rounded-sm shadow-md relative">
            <i class="fab fa-telegram-plane text-2xl"></i>
            <div class="text-center flex-1">
                <p class="font-bold text-lg leading-tight uppercase">JOIN TELEGRAM CHANNEL</p>
                <p class="text-sm font-bold">2</p>
                <p class="text-xs">4.3 PAID HACK</p>
            </div>
            <i class="fab fa-telegram-plane text-2xl"></i>
        </a>

        <!-- Level Up Banner -->
        <div class="w-full relative">
            <img src="levelup.png" alt="Level Up" class="w-full rounded shadow-md border-2 border-yellow-500">
            <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
                <span class="bg-yellow-500 text-black px-4 py-1 font-black text-2xl italic transform -rotate-2">LEVEL
                    UP</span>
            </div>
        </div>

        <!-- Chat/Proof Screenshot Placeholder -->
        <div class="w-full flex justify-center py-2">
            <img src="screenshort1.png" alt="Customer Feedback Proof Image" class="w-[60%] object-cover">
        </div>

        <!-- DM/Buy Button -->
        <a href="https://t.me/+jdK3-Zqi1A42NjM1"
            class="dm-btn w-full flex items-center justify-between px-6 py-4 text-white hover:brightness-110">
            <i class="fab fa-telegram-plane text-2xl"></i>
            <div class="text-center flex-1">
                <p class="font-black text-xl leading-tight italic uppercase">DM TO BUY PAID HACK 4.3</p>
                <p class="text-xs font-bold tracking-widest text-black">SMS FOR VIP HACK</p>
            </div>
            <i class="fab fa-telegram-plane text-2xl"></i>
        </a>

        <!-- Footer Text -->
        <div class="text-center space-y-1 pt-4 px-2">
            <p class="font-black text-sm uppercase">PAID HACK KE LIYE SMS KAREN 100% SAFE</p>
            <p class="font-black text-sm uppercase">HACK HAI DONO CHANNEL KO JOIN KARO.</p>
            <p class="font-black text-sm uppercase">ANDROID AND IOS HACK AVAILABLE</p>
        </div>

        <!-- Timer -->
        <div class="flex space-x-4 text-center py-4">
            <div>
                <span id="days" class="text-2xl timer-unit block">00</span>
                <span class="text-[10px] text-red-700 font-bold uppercase">Days</span>
            </div>
            <span class="text-2xl font-bold text-red-700">:</span>
            <div>
                <span id="hours" class="text-2xl timer-unit block">00</span>
                <span class="text-[10px] text-red-700 font-bold uppercase">Hours</span>
            </div>
            <span class="text-2xl font-bold text-red-700">:</span>
            <div>
                <span id="minutes" class="text-2xl timer-unit block">00</span>
                <span class="text-[10px] text-red-700 font-bold uppercase">Minutes</span>
            </div>
            <span class="text-2xl font-bold text-red-700">:</span>
            <div>
                <span id="seconds" class="text-2xl timer-unit block">00</span>
                <span class="text-[10px] text-red-700 font-bold uppercase">Seconds</span>
            </div>
        </div>

        <!-- Hurry Up Text -->
        <div class="hurry-up-text text-center italic">
            <span class="hurry-blue">HURRY</span> <span class="up-red">UP</span><span class="text-black blink">,</span>
        </div>

        <!-- Email Subscription -->
        <div class="w-full pt-8 pb-12">
            <form id="subscribeForm" class="space-y-4">
                <input type="email" id="email" required placeholder="poisonhackeshackes@gmail.com"
                    class="w-full px-4 py-3 border border-gray-300 rounded shadow-inner text-gray-600 focus:outline-none focus:ring-2 focus:ring-blue-500">
                <button type="submit" class="hidden">Submit</button>
            </form>
        </div>

    </main>

    <!-- Simple Notification Box -->
    <div id="notification"
        class="fixed bottom-4 left-1/2 -translate-x-1/2 bg-gray-800 text-white px-6 py-3 rounded-lg shadow-2xl transform translate-y-24 transition-transform duration-300 flex items-center space-x-2">
        <i class="fas fa-check-circle text-green-400"></i>
        <span>Submitted successfully!</span>
    </div>

    <script>
        // Countdown Timer Logic
        function startCountdown() {
            // Set end date to 24 hours from now for demonstration
            let countdownDate = new Date().getTime() + (24 * 60 * 60 * 1000);

            const timerInterval = setInterval(() => {
                const now = new Date().getTime();
                const distance = countdownDate - now;

                const d = Math.floor(distance / (1000 * 60 * 60 * 24));
                const h = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                const m = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
                const s = Math.floor((distance % (1000 * 60)) / 1000);

                document.getElementById('days').innerText = String(d).padStart(2, '0');
                document.getElementById('hours').innerText = String(h).padStart(2, '0');
                document.getElementById('minutes').innerText = String(m).padStart(2, '0');
                document.getElementById('seconds').innerText = String(s).padStart(2, '0');

                if (distance < 0) {
                    clearInterval(timerInterval);
                    document.getElementById('days').innerText = "00";
                    document.getElementById('hours').innerText = "00";
                    document.getElementById('minutes').innerText = "00";
                    document.getElementById('seconds').innerText = "00";
                }
            }, 1000);
        }

        // Form Handling
        const form = document.getElementById('subscribeForm');
        const notification = document.getElementById('notification');

        form.addEventListener('submit', (e) => {
            e.preventDefault();
            const email = document.getElementById('email').value;

            // Show custom notification instead of alert
            notification.classList.remove('translate-y-24');

            setTimeout(() => {
                notification.classList.add('translate-y-24');
                form.reset();
            }, 3000);
        });

        // Initialize
        window.onload = () => {
            startCountdown();
        };
    </script>
</body>

</html>
